{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build REST_API",
            "type": "shell",
            "command": "${workspaceFolder}\\build.bat",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false
            },
            "problemMatcher": []
        },
        {
            "label": "Run REST_API",
            "type": "shell",
            "command": "C:\\msys64\\ucrt64.exe",
            "args": [
                "bash",
                "-c",
                "cd '${workspaceFolder}' && ./REST_API.exe"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true
            }
        }
    ]
}
