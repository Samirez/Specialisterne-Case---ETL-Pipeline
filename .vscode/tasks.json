{
    "tasks": [
        {
            "type": "shell",
            "label": "Build REST_API (UCRT64)",
            "command": "${env:MSYS2_ROOT}/ucrt64/bin/gcc.exe",
            "args": [
                "-g",
                "-Wall",
                "-Wextra",
                "-I${workspaceFolder}/REST_API/headers",
                "-I${workspaceFolder}/REST_API/include",
                "${workspaceFolder}/REST_API/main.c",
                "${workspaceFolder}/REST_API/user_handler.c",
                "${workspaceFolder}/REST_API/response_builder.c",
                "${workspaceFolder}/REST_API/utils.c",
                "${workspaceFolder}/REST_API/postgres_handler.c",
                "${workspaceFolder}/REST_API/humidity_data_handler.c",
                "-o",
                "${workspaceFolder}/REST_API/REST_API_check.exe",
                "-L",
                "C:/msys64/ucrt64/lib",
                "-lssl",
                "-lcrypto",
                "-lpq",
                "-lmicrohttpd"
            ],
            "options": {
                "cwd": "${workspaceFolder}/REST_API",
                "env": {
                    "PATH": "${env:MSYS2_ROOT}/ucrt64/bin;${env:MSYS2_ROOT}/usr/bin;${env:PATH}"
                }
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ],
    "version": "2.0.0"
}